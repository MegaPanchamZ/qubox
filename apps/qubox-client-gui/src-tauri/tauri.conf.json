{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qubox",
  "version": "0.1.3",
  "identifier": "com.qubox.clientgui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Qubox",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Entertainment",
    "shortDescription": "Low-latency remote desktop for creators and gamers",
    "longDescription": "Qubox is a low-latency remote-desktop client and host agent tuned for creators, gamers, and power users. Install this app on every machine you want to control or connect from.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/qubox-daemon",
      "binaries/qubox-host-agent",
      "binaries/qubox-client-cli"
    ]
  }
}
